{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/HEAD/tooling/cli/config.schema.json",
  "productName": "ScriptStack",
  "version": "3.0.0",
  "identifier": "com.scriptstack.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run frontend:dev",
    "beforeBuildCommand": "npm run frontend:build"
  },
  "app": {
    "windows": [
      {
        "title": "剧本栈 ScriptStack",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
